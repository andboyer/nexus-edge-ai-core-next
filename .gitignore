# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# IDE
.idea
.vscode
*.swp

# OS
.DS_Store
Thumbs.db

# Build artifacts
/build
/dist
/data
# models/ contents are large binaries staged out-of-band (CI bake or
# operator scp); track the directory itself via models/.gitkeep so
# from-source `docker build` doesn't fail on a missing path, but
# never commit the .onnx / manifest files.
/models/*
!/models/.gitkeep
*.db
*.db-journal
*.db-wal
*.db-shm

# Per-box overrides for docker compose (host GIDs, secrets, etc).
# Compose auto-loads deploy/.env on `up`; never commit it.
deploy/.env
deploy/.env.local

# UI
node_modules
ui/dist
ui/*.tsbuildinfo

# Playwright e2e (M7 Step 6F)
ui/playwright-report
ui/test-results
ui/e2e/.engine-state.json

# Tooling caches
.venv
.venv-*
__pycache__
*.pyc

# OTEL
otel.log
