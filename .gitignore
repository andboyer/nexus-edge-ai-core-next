# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# IDE
.idea
.vscode
*.swp

# OS
.DS_Store
Thumbs.db

# Build artifacts
/build
/dist
/data
# models/ contents are large binaries staged out-of-band (CI bake or
# operator scp); track the directory itself via models/.gitkeep so
# from-source `docker build` doesn't fail on a missing path, but
# never commit the .onnx files. The lightweight manifest IS tracked
# (~3 KB) — it's the canonical per-release source of truth for which
# artifacts ship, their preset → file mapping, and per-file sha256
# checksums (patched in place by tools/models/gen_yolo26n.py).
/models/*
!/models/.gitkeep
!/models/models-manifest.json
# Upstream model checkpoints / torchscript dumps occasionally land at
# the repo root from `tools/models/gen_*.py` runs. They are large
# binaries — keep them out of git, same rationale as /models/*.
/*.pt
/*.onnx
/mobileclip2_b.ts
*.db
*.db-journal
*.db-wal
*.db-shm

# Per-box overrides for docker compose (host GIDs, secrets, etc).
# Compose auto-loads deploy/.env on `up`; never commit it.
deploy/.env
deploy/.env.local

# UI
node_modules
ui/dist
ui/*.tsbuildinfo

# Playwright e2e (M7 Step 6F)
ui/playwright-report
ui/test-results
ui/e2e/.engine-state.json

# Tooling caches
.venv
.venv-*
__pycache__
*.pyc

# OTEL
otel.log

# Personal VS Code workspace file (machine-local paths).
/nexus-edge-ai-core-next.code-workspace
