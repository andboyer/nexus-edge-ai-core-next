{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexusedge.ai/proto/v1.json",
  "title": "Nexus edge↔cloud wire protocol",
  "description": "Canonical schema for v1 of the wire envelope and the eight message kinds Phase 1 needs (heartbeat, heartbeat_ack, alert, alert_ack, entitlement_update, rpc_call, rpc_response, close_session). HUMAN-EDITED source of truth. Rust types live in proto/generated/rust/v1.rs; TypeScript zod schemas in proto/generated/ts/v1.ts. `cargo xtask gen-proto` regenerates both; CI fails if they're stale.",
  "type": "object",
  "$defs": {
    "Uuid":        { "type": "string", "format": "uuid", "minLength": 36, "maxLength": 36 },
    "Timestamp":   { "type": "string", "format": "date-time" },
    "UnixSeconds": { "type": "integer", "minimum": 0 },

    "Envelope": {
      "type": "object",
      "description": "Every WebSocket text frame is exactly one of these. Max 256 KiB total.",
      "required": ["v", "id", "ts", "kind", "payload"],
      "additionalProperties": false,
      "properties": {
        "v":           { "const": 1 },
        "id":          { "$ref": "#/$defs/Uuid",      "description": "Sender-generated UUIDv7 correlation id." },
        "ts":          { "$ref": "#/$defs/Timestamp", "description": "Sender wall-clock at emit. Diagnostics only — never used for security." },
        "kind":        { "$ref": "#/$defs/MessageKind" },
        "in_reply_to": { "$ref": "#/$defs/Uuid",      "description": "Required when this envelope is a response (e.g. rpc_response, *_ack)." },
        "seq":         { "type": "integer", "minimum": 0, "description": "Phase 1.16: per-core monotonic sequence number. Optional in v1; required from Phase 1.16 onward." },
        "trace":       { "$ref": "#/$defs/TraceContext", "description": "Phase 1.14: distributed-trace propagation. Optional in v1." },
        "payload":     { "type": "object", "description": "Kind-specific body. May be {} but never null." }
      }
    },

    "MessageKind": {
      "type": "string",
      "enum": [
        "heartbeat",
        "heartbeat_ack",
        "alert",
        "alert_ack",
        "entitlement_update",
        "rpc_call",
        "rpc_response",
        "close_session"
      ]
    },

    "TraceContext": {
      "type": "object",
      "required": ["trace_id", "parent_span_id"],
      "additionalProperties": false,
      "properties": {
        "trace_id":       { "type": "string", "minLength": 32, "maxLength": 32, "description": "16-byte W3C trace-id, hex-encoded." },
        "parent_span_id": { "type": "string", "minLength": 16, "maxLength": 16, "description": "8-byte W3C span-id, hex-encoded." }
      }
    },

    "HeartbeatPayload": {
      "type": "object",
      "description": "Edge → Cloud. Sent every 30 s. Minimum health snapshot.",
      "required": ["version", "tier", "uptime_s", "queued_alerts", "online_cameras"],
      "additionalProperties": false,
      "properties": {
        "version":         { "type": "string", "description": "Engine semver, e.g. \"0.5.0\"." },
        "tier":            { "type": "string", "enum": ["t10", "t24", "t36", "t36s", "t64"], "description": "Hardware tier from config/tiers/." },
        "uptime_s":        { "type": "integer", "minimum": 0 },
        "queued_alerts":   { "type": "integer", "minimum": 0 },
        "online_cameras":  { "type": "integer", "minimum": 0 },
        "edge_ts_unix_ms": { "type": "integer", "minimum": 0, "description": "Phase 1.15: edge wall-clock for skew tracking (gateway writes EMA to cores.last_skew_ms)." },
        "release":         { "$ref": "#/$defs/ReleaseStatus", "description": "Phase 7: OTA-update status block. Omitted by pre-Phase-7 edges." }
      }
    },

    "ReleaseStatus": {
      "type": "object",
      "required": ["current_version", "channel", "recording_active"],
      "additionalProperties": false,
      "properties": {
        "current_version":         { "type": "string" },
        "channel":                 { "type": "string", "enum": ["stable", "beta", "fast"] },
        "last_update_attempt_at":  { "$ref": "#/$defs/Timestamp" },
        "last_update_result":      { "type": "string", "enum": ["success", "failed", "in_progress"] },
        "recording_active":        { "type": "boolean" }
      }
    },

    "HeartbeatAckPayload": {
      "type": "object",
      "description": "Cloud → Edge. Reply to a heartbeat. May hint at cert rotation after day 75.",
      "required": ["server_ts"],
      "additionalProperties": false,
      "properties": {
        "server_ts":   { "$ref": "#/$defs/Timestamp" },
        "cert_rotate": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason"],
          "properties": {
            "reason": { "type": "string", "enum": ["rotate_due", "revoked", "ca_rolled"] }
          }
        }
      }
    },

    "AlertPayload": {
      "type": "object",
      "description": "Edge → Cloud. AlertEvent — shape mirrors nexus-types/src/lib.rs on the edge side.",
      "required": ["edge_event_id", "camera_id", "ts", "severity"],
      "additionalProperties": false,
      "properties": {
        "edge_event_id":     { "type": "string", "description": "Core-local id. Dedup key on cloud INSERT (cores.id × edge_event_id)." },
        "edge_rule_id":      { "type": "string" },
        "camera_id":         { "type": "integer", "minimum": 0, "description": "Per-core integer id (matches cameras.edge_camera_id)." },
        "ts":                { "$ref": "#/$defs/Timestamp" },
        "severity":          { "type": "integer", "minimum": 0, "maximum": 4 },
        "matched_label":     { "type": "string" },
        "confidence":        { "type": "number", "minimum": 0, "maximum": 1 },
        "bbox":              { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4, "description": "[x, y, w, h] normalised 0..1" },
        "snapshot_blob_url": { "type": "string", "format": "uri" },
        "clip_blob_url":     { "type": "string", "format": "uri" },
        "attached_history":  { "type": "boolean", "description": "Phase 21.2 — clip pre-attached on edge." }
      }
    },

    "AlertAckPayload": {
      "type": "object",
      "description": "Cloud → Edge. permanent_failure tells the edge outbox to mark the row suppressed.",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["received", "permanent_failure"] },
        "reason": { "type": "string" }
      }
    },

    "EntitlementUpdatePayload": {
      "type": "object",
      "description": "Cloud → Edge. Push triggered by Stripe webhook or initial enrollment. Edge persists + applies immediately.",
      "required": ["jwt"],
      "additionalProperties": false,
      "properties": {
        "jwt": { "type": "string", "description": "Compact JWS. Verified with the entitlement public key bundled at enrollment." }
      }
    },

    "ActorTokenJwt": {
      "type": "string",
      "description": "Compact JWS (Ed25519). Header `{alg:\"EdDSA\", kid:<keyvault-key-id>}`. Claims per WIRE_PROTOCOL.md §11.2; engine verifies before applying any state-mutating rpc_call. See ActorTokenClaims for the structural shape of the inner JWT body."
    },

    "ActorTokenClaims": {
      "type": "object",
      "description": "Structural shape of the JWT body inside ActorTokenJwt. Not transmitted standalone — included in this schema so codegen produces a typed verifier struct on the edge side.",
      "required": ["iss", "sub", "aud", "org_id", "core_id", "role", "http_method", "path", "jti", "iat", "exp"],
      "additionalProperties": false,
      "properties": {
        "iss":         { "type": "string", "description": "https://entitlement.nexus.example" },
        "sub":         { "type": "string", "description": "User UUID, or `system:<svc-name>`." },
        "aud":         { "const": "nexus-edge-rpc" },
        "org_id":      { "$ref": "#/$defs/Uuid" },
        "core_id":     { "$ref": "#/$defs/Uuid" },
        "role":        { "type": "string", "enum": ["owner", "admin", "operator", "viewer", "system"] },
        "http_method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path":        { "type": "string", "description": "Exact match against rpc_call.payload.path." },
        "jti":         { "$ref": "#/$defs/Uuid" },
        "iat":         { "$ref": "#/$defs/UnixSeconds" },
        "exp":         { "$ref": "#/$defs/UnixSeconds", "description": "MUST be iat + 30 s." }
      }
    },

    "RpcCallPayload": {
      "type": "object",
      "description": "Cloud → Edge. Proxies an HTTP call to the edge's loopback admin API. State-mutating methods MUST carry actor_token.",
      "required": ["method", "path"],
      "additionalProperties": false,
      "properties": {
        "method":       { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path":         { "type": "string", "description": "Absolute path on the edge loopback admin API." },
        "headers":      { "type": "object", "additionalProperties": { "type": "string" } },
        "body":         { "type": "string", "contentEncoding": "base64", "description": "Optional request body. Base64 of the raw bytes." },
        "actor_token":  { "$ref": "#/$defs/ActorTokenJwt" },
        "request_id":   { "$ref": "#/$defs/Uuid", "description": "Phase 1.16: propagated from HTTP Idempotency-Key for end-to-end dedup." }
      }
    },

    "RpcResponsePayload": {
      "type": "object",
      "description": "Edge → Cloud. Reply to an rpc_call. Uses envelope.in_reply_to to bind to the original.",
      "required": ["status", "body"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "body":   {
          "oneOf": [
            { "type": "object" },
            { "$ref": "#/$defs/RpcErrorBody" }
          ]
        }
      }
    },

    "RpcErrorBody": {
      "type": "object",
      "description": "Shape of body on 4xx/5xx responses. See WIRE_PROTOCOL.md §4.3 for the full code catalogue.",
      "required": ["error", "message"],
      "additionalProperties": false,
      "properties": {
        "error": {
          "type": "string",
          "enum": [
            "unauthorized",
            "not_found",
            "seat_limit",
            "internal_error",
            "entitlement_expired",
            "core_offline",
            "actor_token_missing",
            "actor_token_invalid",
            "signature_invalid",
            "digest_mismatch",
            "recording_in_progress",
            "compose_file_tampered",
            "rollback_also_failed",
            "compatibility_refused"
          ]
        },
        "message": { "type": "string" }
      }
    },

    "CloseSessionPayload": {
      "type": "object",
      "description": "Cloud → Edge. Server-initiated clean disconnect. Edge reconnects immediately.",
      "required": ["reason"],
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string",
          "enum": ["gateway_redeploy", "cert_revoked", "version_unsupported", "admin_revoked"]
        }
      }
    }
  },

  "oneOf": [
    { "allOf": [ { "$ref": "#/$defs/Envelope" }, { "properties": { "kind": { "const": "heartbeat" },          "payload": { "$ref": "#/$defs/HeartbeatPayload" } } } ] },
    { "allOf": [ { "$ref": "#/$defs/Envelope" }, { "properties": { "kind": { "const": "heartbeat_ack" },      "payload": { "$ref": "#/$defs/HeartbeatAckPayload" } } } ] },
    { "allOf": [ { "$ref": "#/$defs/Envelope" }, { "properties": { "kind": { "const": "alert" },              "payload": { "$ref": "#/$defs/AlertPayload" } } } ] },
    { "allOf": [ { "$ref": "#/$defs/Envelope" }, { "properties": { "kind": { "const": "alert_ack" },          "payload": { "$ref": "#/$defs/AlertAckPayload" } } } ] },
    { "allOf": [ { "$ref": "#/$defs/Envelope" }, { "properties": { "kind": { "const": "entitlement_update" }, "payload": { "$ref": "#/$defs/EntitlementUpdatePayload" } } } ] },
    { "allOf": [ { "$ref": "#/$defs/Envelope" }, { "properties": { "kind": { "const": "rpc_call" },           "payload": { "$ref": "#/$defs/RpcCallPayload" } } } ] },
    { "allOf": [ { "$ref": "#/$defs/Envelope" }, { "properties": { "kind": { "const": "rpc_response" },       "payload": { "$ref": "#/$defs/RpcResponsePayload" } } } ] },
    { "allOf": [ { "$ref": "#/$defs/Envelope" }, { "properties": { "kind": { "const": "close_session" },      "payload": { "$ref": "#/$defs/CloseSessionPayload" } } } ] }
  ]
}
